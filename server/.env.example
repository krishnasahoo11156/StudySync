# Get your Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The verified sender email in your Resend account (use your domain or resend.dev subdomain)
FROM_EMAIL=StudySync <hello@yourdomain.com>

# Port for the Express server (Railway will auto-set this)
PORT=3001

# Your deployed frontend URL (for CORS — update after Railway deploy)
FRONTEND_URL=http://localhost:5173
